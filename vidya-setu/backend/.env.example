# AWS Bedrock Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-south-1

# Bhashini Configuration (optional)
BHASHINI_API_KEY=your_bhashini_key_here
BHASHINI_USER_ID=your_bhashini_user_id_here

# Set to "true" to use mock responses without real API calls
MOCK_MODE=true

# Backend CORS - set to your Vercel/Netlify URL in production
FRONTEND_URL=http://localhost:5173
